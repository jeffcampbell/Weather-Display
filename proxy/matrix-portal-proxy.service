[Unit]
Description=Matrix Portal HTTP Proxy
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/Development/matrix-portal-proxy
ExecStart=/usr/bin/python3 /home/pi/Development/matrix-portal-proxy/server.py
Restart=always
RestartSec=5
Environment=PORT=6590

[Install]
WantedBy=multi-user.target
